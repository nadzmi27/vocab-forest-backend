### Install extension REST Client on vscode extension
### Variables to avoid repitition on testing
@hostname = localhost
@port = 8000
@host = {{hostname}}:{{port}}
@userId = {{$dotenv USER_ID}}
@collectionId = {{$dotenv COLLECTION_ID}}
@token = {{$dotenv TOKEN}}
# @word = bank

###
POST http://{{host}}/
content-type: application/json
Authorization: Bearer {{token}}

{
    "word": "bank",
    "userId": "{{userId}}",
    "collectionId": "{{collectionId}}"
}

